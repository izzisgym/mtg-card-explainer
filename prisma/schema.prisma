generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id          String    @id
  name        String
  oracleText  String?
  typeLine    String
  manaCost    String?
  colors      String[]
  setCode     String
  setName     String?
  rarity      String?
  imageUrl    String?
  scryfallUri String
  power       String?
  toughness   String?
  loyalty     String?
  keywords    String[]
  explanation String?
  explainedAt DateTime?
  releasedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([name])
  @@index([setCode])
  @@index([colors])
  @@index([releasedAt])
}
